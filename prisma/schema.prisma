generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  settings  Json     @default("{}")
  createdAt DateTime @default(now())

  practiceRecords PracticeRecord[]
  paperProgresses PaperProgress[]
}

model PaperProgress {
  id                   Int      @id @default(autoincrement())
  userId               Int
  paperId              Int
  kind                 String   @default("paper")
  sprintGroupNumber    Int?
  currentQuestionIndex Int      @default(0)
  completed            Boolean  @default(false)
  score                Int?
  questionIds          Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  practiceRecords PracticeRecord[]

  @@index([userId, paperId])
  @@index([userId, kind])
}

model PracticeRecord {
  id             Int      @id @default(autoincrement())
  userId         Int
  paperId        Int
  progressId     Int
  questionId     Int
  selectedAnswer String
  isCorrect      Boolean
  createdAt      DateTime @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress PaperProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@unique([progressId, paperId, questionId])
  @@index([userId, paperId])
  @@index([userId, paperId, questionId])
}
